{
  "_comment": "服务器配置文件 - 部署时请复制为 config.json 并修改相应配置。默认推荐连接外部 MQTT broker。若服务运行在 WSL 且开发板经 Windows 访问，请将 public_host 配成 Windows 主机局域网 IP，并在 Windows 上做端口转发。",
  
  "public_host": "cloud.yshut.cn",
  
  "qt_client": {
    "_comment": "QT客户端连接配置（当服务器作为客户端连接QT时使用）",
    "host": "192.168.1.100",
    "port": 5051
  },
  
  "web_server": {
    "_comment": "Web服务器配置",
    "host": "0.0.0.0",
    "port": 18080,
    "debug": false
  },

  "auth": {
    "_comment": "登录认证配置。推荐使用 pbkdf2_sha256 哈希，格式: pbkdf2_sha256$迭代次数$salt$hex摘要",
    "enable": true,
    "username": "admin",
    "password_hash": "",
    "viewer_username": "viewer",
    "viewer_password_hash": "",
    "secret_key": "change-this-session-secret-in-production",
    "max_failures": 6,
    "lockout_seconds": 300,
    "audit_log_path": "./uploads/auth_audit.log",
    "cookie_secure": true,
    "cookie_name": "app_lvgl_session",
    "trust_proxy": true,
    "trust_proxy_hops": 1
  },
  
  "tcp_hub": {
    "_comment": "TCP Hub配置（QT客户端反向连接到服务器）",
    "listen_host": "0.0.0.0",
    "listen_port": 5051
  },
  
  "websocket": {
    "_comment": "WebSocket服务器配置（QT客户端通过WebSocket连接）",
    "listen_host": "0.0.0.0",
    "listen_port": 5052
  },

  "mqtt": {
    "_comment": "MQTT 配置。服务端本身不是 broker，而是连接到外部 broker 并桥接到 Web UI。若 host=127.0.0.1，可由 web_server.py 自动拉起本地 mosquitto。",
    "enable": true,
    "host": "127.0.0.1",
    "port": 1883,
    "embedded_broker": false,
    "embedded_bind_host": "0.0.0.0",
    "embedded_port": 1883,
    "auto_start_local_broker": true,
    "mosquitto_bin": "mosquitto",
    "username": "",
    "password": "",
    "client_id": "app_lvgl_server",
    "keepalive_s": 30,
    "qos": 1,
    "topic_prefix": "app_lvgl",
    "use_tls": false,
    "ws_url": ""
  },
  
  "paths": {
    "_comment": "文件路径配置",
    "base_dir": "/mnt",
    "dbc_dir": "./uploads/dbc",
    "static_dir": "./static",
    "upload_dir": "./uploads"
  },
  
  "network": {
    "_comment": "网络配置",
    "socket_timeout": 3.0,
    "max_connections": 100,
    "keepalive": true
  },
  
  "logging": {
    "_comment": "日志配置",
    "level": "info",
    "file": "./logs/server.log",
    "max_size_mb": 100,
    "backup_count": 5
  },
  
  "security": {
    "_comment": "安全配置（未来扩展）",
    "enable_auth": false,
    "secret_key": "change-this-secret-key-in-production",
    "allowed_origins": ["*"]
  },
  
  "features": {
    "_comment": "功能开关",
    "enable_can_parser": true,
    "enable_dbc_support": true,
    "enable_file_manager": true,
    "enable_uds": true
  },

  "state": {
    "_comment": "后端状态存储（用于前端刷新后快速恢复状态；默认 SQLite）",
    "db_enable": true,
    "db_path": "./uploads/state.sqlite3"
  }
}
